#!/bin/env bash

# THIS REPO SETS UP THE DEV ENVIRONMMENT TO AUTOMATE
# THE PROCESS OF PKG BUILDING AND DEPLOYING TO REPO

# RUN THIS SCRIPT ONCE

doc_url=https://n0ctaneteam.github.io/N0ctOS

# Array of script names
SCRIPTS=(
    "auto-all"
    "build-all"
    "move-all"
    "push-to-repo"
)


mkdir ~/Projects/N0ctOS
cd ~/Projects/N0ctOS

echo "############################################################"
echo "###   Do u want to clone full repo ? (or just latest ?)  ###"
echo "############################################################"
echo "1 (latest) ; 2 (full)    [default:1]"
read git_clone_type

case $git_clone_type in
	"2")
		git_clone_type="full"
		;;
	*)
		git_clone_type="latest"
		;;
esac

echo -e "\n\n\ncloning the $git_clone_type git(s)"
# clone the latest git
git clone https://github.com/n0ctaneteam/N0ctOS-PKGBUILDs.git
git clone https://github.com/n0ctaneteam/N0ctOS-pkg-repo.git

cd ~/Projects/N0ctOS/N0ctOS-PKGBUILDs
git lfs install
git lfs track "*.pkg.tar.zst"

cd ~/Projects/N0ctOS/N0ctOS-pkg-repo
git lfs install
git lfs track "*.pkg.tar.zst"

# Loop through scripts
for FILE in "${SCRIPTS[@]}"; do
    chmod +x ~/Projects/N0ctOS/N0ctOS-PKGBUILDs/"$FILE"
    echo "chmod-ed $FILE"
done
echo "########################################"
echo "!!!        Dev Env setup done        !!!"
echo "########################################"

echo -e "\n\n"
echo -e "Read the docs for more info"
echo $doc_url