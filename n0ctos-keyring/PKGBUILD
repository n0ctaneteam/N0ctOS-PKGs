pkgname=n0ctos-keyring
pkgver=20260518 # yyyymmdd
pkgrel=2
pkgdesc="N0ctOS PGP keyring"
arch=('any')
url="https://github.com/n0ctaneteam/N0ctOS-PKGs"
license=(GPL-3.0-or-later)
depends=('pacman')

source=('n0ctos.gpg'
        'n0ctos-trusted'
        'n0ctos-revoked')        # ← add this

sha256sums=($(sha256sum n0ctos.gpg | cut -d' ' -f1)
            $(sha256sum n0ctos-trusted | cut -d' ' -f1)
            $(sha256sum n0ctos-revoked | cut -d' ' -f1))  # ← add this

package() {
    install -Dm0644 "${srcdir}/n0ctos.gpg" \
        "${pkgdir}/usr/share/pacman/keyrings/n0ctos.gpg"

    install -Dm0644 "${srcdir}/n0ctos-trusted" \
        "${pkgdir}/usr/share/pacman/keyrings/n0ctos-trusted"

    install -Dm0644 "${srcdir}/n0ctos-revoked" \
        "${pkgdir}/usr/share/pacman/keyrings/n0ctos-revoked"   # ← add this
}