# Maintainer: N0ctane._.Dev <n0ctanedev@gmail.com>

pkgname=n0ctos-keyring
pkgver=1.0
pkgrel=10
pkgdesc="N0ctOS PGP keyring"
arch=('any')
url="https://github.com/n0ctaneteam/N0ctOS-PKGs"
license=('GPL3')
install=n0ctos-keyring.install
provides=("n0ctos-keyring")
conflicts=("n0ctos-keyring")
source=(
  "n0ctos.gpg"
  "n0ctos-trusted"
  "n0ctos-revoked"
)
sha256sums=('SKIP' 'SKIP' 'SKIP')


package() {
    install -Dm644 "$startdir/n0ctos.gpg"     "$pkgdir/usr/share/pacman/keyrings/n0ctos.gpg"
    install -Dm644 "$startdir/n0ctos-trusted"  "$pkgdir/usr/share/pacman/keyrings/n0ctos-trusted"
    install -Dm644 "$startdir/n0ctos-revoked"  "$pkgdir/usr/share/pacman/keyrings/n0ctos-revoked"
}