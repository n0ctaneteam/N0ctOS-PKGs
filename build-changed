#!/usr/bin/env bash

clear
# =========================
# Config
# =========================
PREFIX="n0ctos-"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GITHUB_USER="n0ctaneteam"
GITHUB_REPO="N0ctOS-PKGs"
GITHUB_BRANCH="main"
REMOTE_URL="https://github.com/${GITHUB_USER}/${GITHUB_REPO}.git"

# Files to check for changes inside each package folder
CHECK_FILES=(
    "PKGBUILD"
    "*.cfg/*"
    "*.install"
    "*.patch"
)

# Notification helper
NOTIF_APP="N0ctOS PKG Compiler"
NOTIF_ICON="system-run"
notify() {
    local timeout="${1}"
    local summary="${2}"
    local body="${3}"
    notify-send -a "$NOTIF_APP" -i "$NOTIF_ICON" -t "$timeout" "$summary" "$body"
}

# Temp dir to shallow-clone the remote repo into (auto-cleaned on exit)
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

# =========================
# Clone remote repo (shallow, no history needed)
# =========================
echo "Fetching remote repo (shallow clone)..."
notify 5000 "Repo Check Started" "Fetching $GITHUB_REPO from GitHub..."

git clone --depth=1 --branch "$GITHUB_BRANCH" --quiet "$REMOTE_URL" "$TMP_DIR"
if [ $? -ne 0 ]; then
    echo "[ERROR] Failed to clone $REMOTE_URL"
    echo "        Check your internet connection or repo URL."
    notify 10000 "Repo Check Failed" "Could not clone $REMOTE_URL — check your connection."
    exit 1
fi
echo "Remote fetched OK."
notify 5000 "Repo Fetched OK" "Successfully cloned $GITHUB_REPO."
echo

# =========================
# Find matching local folders
# =========================
echo "Searching in: $SCRIPT_DIR"
echo "Looking for folders starting with: $PREFIX"
echo

mapfile -t MATCHING_DIRS < <(
    find "$SCRIPT_DIR" \
        -mindepth 1 \
        -maxdepth 1 \
        -type d \
        -name "${PREFIX}*" \
        | sort
)

if [ ${#MATCHING_DIRS[@]} -eq 0 ]; then
    echo "No matching folders found."
    notify 6000 "Nothing to Do" "No local folders matching '${PREFIX}*' were found."
    exit 0
fi

echo "Found ${#MATCHING_DIRS[@]} matching folder(s):"
printf ' - %s\n' "${MATCHING_DIRS[@]}"
echo



# =========================
# GPG Key Setup
# =========================
echo
echo "############################################################"
echo "###              GPG Signing Key Setup                   ###"
echo "############################################################"

# Collect keys that have secret (private) keys available — those are the ones
# that can actually sign packages.
mapfile -t GPG_KEYS < <(
    gpg --list-secret-keys --with-colons 2>/dev/null \
        | awk -F: '
            /^sec/ { keyid = $5 }
            /^uid/ { print keyid " — " $10; keyid="" }
        '
)

setup_gpg_files() {
    local KEY_ID="$1"

    mkdir -p ~/.gnupg
    chmod 700 ~/.gnupg

    # Write to ~/.makepkg.conf (user-level override, no sudo needed)
    MAKEPKG_USER_CONF="$HOME/.makepkg.conf"
    GPGKEY_LINE="GPGKEY=\"$KEY_ID\""

    if grep -q "^GPGKEY=" "$MAKEPKG_USER_CONF" 2>/dev/null; then
        sed -i "s/^GPGKEY=.*/$GPGKEY_LINE/" "$MAKEPKG_USER_CONF"
        echo "  Updated GPGKEY in $MAKEPKG_USER_CONF"
    else
        echo "$GPGKEY_LINE" >> "$MAKEPKG_USER_CONF"
        echo "  Written GPGKEY to $MAKEPKG_USER_CONF"
    fi

    # Reload gpg-agent so the key is live immediately
    gpg-connect-agent reloadagent /bye &>/dev/null
    echo "  GPG agent reloaded."
    echo "  Done — packages will be signed with key: $KEY_ID"
}

if [ ${#GPG_KEYS[@]} -eq 0 ]; then
    # ── No keys found ────────────────────────────────────────────────────────
    echo
    echo "  [!] No GPG secret keys found on this machine."
    echo "      Starting GPG key creation wizard..."
    echo

    # Collect details for an unattended batch key generation
    read -rp "  Full Name  : " GPG_NAME
    read -rp "  Email      : " GPG_EMAIL
    read -rp "  Comment    (optional, press Enter to skip): " GPG_COMMENT
    read -rsp "  Passphrase (leave blank for no passphrase): " GPG_PASS
    echo

    # Build the batch input file
    BATCH_FILE="$(mktemp)"
    cat > "$BATCH_FILE" <<EOF
%echo Generating GPG key for N0ctOS package signing...
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $GPG_NAME
Name-Comment: ${GPG_COMMENT:-N0ctOS PKG Signing}
Name-Email: $GPG_EMAIL
Expire-Date: 0
Passphrase: $GPG_PASS
%commit
%echo Key generation complete.
EOF

    echo "  Generating key (this may take a moment)..."
    gpg --batch --gen-key "$BATCH_FILE"
    GEN_EXIT=$?
    rm -f "$BATCH_FILE"

    if [ $GEN_EXIT -ne 0 ]; then
        echo "  [ERROR] GPG key generation failed (exit $GEN_EXIT)."
        echo "          Run 'gpg --full-gen-key' manually and re-run this script."
        exit 1
    fi

    # Grab the fingerprint of the key we just created
    NEW_KEY_ID="$(
        gpg --list-secret-keys --with-colons "$GPG_EMAIL" 2>/dev/null \
            | awk -F: '/^sec/ { print $5; exit }'
    )"

    echo
    echo "  [OK] Key created: $NEW_KEY_ID"
    setup_gpg_files "$NEW_KEY_ID"

else
    # ── One or more keys found ────────────────────────────────────────────────
    echo
    echo "  Found the following GPG secret key(s):"
    INDEX=1
    for KEY in "${GPG_KEYS[@]}"; do
        echo "    $INDEX) $KEY"
        (( INDEX++ ))
    done
    echo "    $INDEX) Create a new key"
    echo

    echo "  Select a key to use (overide data of ~/.makepkg.conf)"
    read -rp  "  (default: 1) : " KEY_CHOICE
    KEY_CHOICE="${KEY_CHOICE:-1}"

    if [ "$KEY_CHOICE" -eq "$INDEX" ] 2>/dev/null; then
        # User wants a brand-new key — fall through to the creation wizard
        echo
        echo "  Starting GPG key creation wizard..."
        read -rp "  Full Name  : " GPG_NAME
        read -rp "  Email      : " GPG_EMAIL
        read -rp "  Comment    (optional, press Enter to skip): " GPG_COMMENT
        read -rsp "  Passphrase (leave blank for no passphrase): " GPG_PASS
        echo

        BATCH_FILE="$(mktemp)"
        cat > "$BATCH_FILE" <<EOF
%echo Generating GPG key for N0ctOS package signing...
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $GPG_NAME
Name-Comment: ${GPG_COMMENT:-N0ctOS PKG Signing}
Name-Email: $GPG_EMAIL
Expire-Date: 0
Passphrase: $GPG_PASS
%commit
%echo Key generation complete.
EOF

        echo "  Generating key (this may take a moment)..."
        gpg --batch --gen-key "$BATCH_FILE"
        GEN_EXIT=$?
        rm -f "$BATCH_FILE"

        if [ $GEN_EXIT -ne 0 ]; then
            echo "  [ERROR] GPG key generation failed (exit $GEN_EXIT)."
            echo "          Run 'gpg --full-gen-key' manually and re-run this script."
            exit 1
        fi

        NEW_KEY_ID="$(
            gpg --list-secret-keys --with-colons "$GPG_EMAIL" 2>/dev/null \
                | awk -F: '/^sec/ { print $5; exit }'
        )"

        echo
        echo "  [OK] Key created: $NEW_KEY_ID"
        setup_gpg_files "$NEW_KEY_ID"

    elif [ "$KEY_CHOICE" -ge 1 ] && [ "$KEY_CHOICE" -lt "$INDEX" ] 2>/dev/null; then
        # User picked one of the existing keys
        CHOSEN="${GPG_KEYS[$((KEY_CHOICE - 1))]}"
        CHOSEN_ID="$(echo "$CHOSEN" | awk '{ print $1 }')"
        echo
        echo "  [OK] Using existing key: $CHOSEN"
        setup_gpg_files "$CHOSEN_ID"

    else
        echo "  [WARN] Invalid selection — skipping GPG setup."
        echo "         Run 'gpg --full-gen-key' manually and update GPGKEY in makepkg.conf."
    fi
fi


# =========================
# Loop through folders
# =========================
BUILT=0
SKIPPED=0
FAILED=0
CHANGED=0

for DIR in "${MATCHING_DIRS[@]}"; do
    BASENAME="$(basename "$DIR")"
    REMOTE_DIR="$TMP_DIR/$BASENAME"

    if [ "$DIR" == "__deployed__"]; then
        continue
    fi

    echo "──────────────────────────────────────"
    echo "Checking: $BASENAME"

    if [ ! -f "$DIR/PKGBUILD" ]; then
        echo "  [SKIP] No local PKGBUILD — skipping."
        (( SKIPPED++ ))
        continue
    fi

    if [ ! -d "$REMOTE_DIR" ]; then
        echo "  [WARN] Folder not found in remote repo — building anyway."
        SHOULD_BUILD=true
    else
        # Compare only the files defined in CHECK_FILES
        DIFF_OUT=""
        DIFF_COUNT=0
        for PATTERN in "${CHECK_FILES[@]}"; do
            for LOCAL_FILE in "$DIR"/$PATTERN; do
                [ -e "$LOCAL_FILE" ] || continue
                FILENAME="$(basename "$LOCAL_FILE")"
                REMOTE_FILE="$REMOTE_DIR/$FILENAME"
                if [ ! -f "$REMOTE_FILE" ]; then
                    DIFF_OUT+="Only in local: $FILENAME"$'\n'
                    (( DIFF_COUNT++ ))
                else
                    FILE_DIFF="$(diff -q "$LOCAL_FILE" "$REMOTE_FILE" 2>/dev/null)"
                    if [ -n "$FILE_DIFF" ]; then
                        DIFF_OUT+="$FILE_DIFF"$'\n'
                        (( DIFF_COUNT++ ))
                    fi
                fi
            done
        done

        if [ -z "$DIFF_OUT" ]; then
            echo "  [SKIP] Nothing changed for $BASENAME — skipping build."
            (( SKIPPED++ ))
            continue
        else
            echo "  [CHANGED] Differences found:"
            echo "$DIFF_OUT" | sed 's/^/    /'
            (( CHANGED++ ))
            notify 5000 "Changes Detected: $BASENAME" "$DIFF_COUNT file(s) differ from remote."
            SHOULD_BUILD=true
        fi
    fi

    # =========================
    # Build
    # =========================
    if [ "${SHOULD_BUILD:-false}" = true ]; then
        notify 5000 "Build Started: $BASENAME" "Running makepkg for $BASENAME..."
        (
            cd "$DIR" || exit 1
            makepkg -sCcf --sign
        )
        BUILD_EXIT=$?
        if [ $BUILD_EXIT -eq 0 ]; then
          # delete old pkg files
            rm -rfv $SCRIPT_DIR/__deployed__/x86_64/$BASENAME-*
          # move newly built files
            mv $SCRIPT_DIR/$BASENAME/*.pkg.* "$SCRIPT_DIR/__deployed__/x86_64/" -v
          
            echo "  [OK] Build succeeded: $BASENAME"
            notify 5000 "Build Succeeded: $BASENAME" "$BASENAME compiled and signed successfully."
            (( BUILT++ ))
        else
            echo "  [ERROR] Build failed for $BASENAME (exit $BUILD_EXIT)"
            notify 10000 "Build Failed: $BASENAME" "makepkg exited with code $BUILD_EXIT."
            (( FAILED++ ))
        fi
    fi

    unset SHOULD_BUILD
done

# =========================
# Summary
# =========================
echo
echo "══════════════════════════════════════"
echo "  Built:   $BUILT"
echo "  Skipped: $SKIPPED (no changes)"
echo "  Failed:  $FAILED"
echo "══════════════════════════════════════"
echo "Done."

notify 8000 "Compiler Done" "Built: $BUILT  |  Skipped: $SKIPPED  |  Failed: $FAILED"