#!/usr/bin/env bash

clear
# =========================
# Config
# =========================
PREFIX="n0ctos-"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# =========================
# Find matching local folders
# =========================
echo "Searching in: $SCRIPT_DIR"
echo "Looking for folders starting with: $PREFIX"
echo

mapfile -t MATCHING_DIRS < <(
    find "$SCRIPT_DIR" \
        -mindepth 1 \
        -maxdepth 1 \
        -type d \
        -name "${PREFIX}*" \
        | sort
)

if [ ${#MATCHING_DIRS[@]} -eq 0 ]; then
    echo "No matching folders found."
    notify-send -a 'N0ctOS PKGBUILD compiler' -t 5000 \
        -i dialog-warning \
        'N0ctOS PKGBUILD compiler' "No matching folders found."
    exit 0
fi

echo "══════════════════════════════════════"
echo "  Packages queued to build: ${#MATCHING_DIRS[@]}"
for DIR in "${MATCHING_DIRS[@]}"; do
    echo "    → $(basename "$DIR")"
done
echo "══════════════════════════════════════"
echo

read -rp "Proceed with build? [Y/n] (default: Y): " PROCEED
PROCEED="${PROCEED:-Y}"
if [[ ! "$PROCEED" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    notify-send 5000 "Build Aborted" "User chose not to proceed."
    exit 1
fi
echo

notify-send -a 'N0ctOS PKGBUILD compiler' -t 5000 \
    -i system-run \
    'N0ctOS PKGBUILD compiler' "Starting build of $TOTAL package(s)…"


./gpg-key-set

# =========================
# Loop through folders
# =========================
BUILT=0
SKIPPED=0
FAILED=0
COUNT=0

for DIR in "${MATCHING_DIRS[@]}"; do
    BASENAME="$(basename "$DIR")"
    (( COUNT++ ))

    echo "──────────────────────────────────────"
    echo "[$COUNT/$TOTAL] Processing: $BASENAME"

    if [ ! -f "$DIR/PKGBUILD" ]; then
        echo "  [SKIP] No local PKGBUILD — skipping."
        notify-send -a 'N0ctOS PKGBUILD compiler' -t 4000 \
            -i dialog-warning \
            "[$COUNT/$TOTAL] Skipped: $BASENAME" "No local PKGBUILD found."
        (( SKIPPED++ ))
        continue
    fi

    echo "  [BUILD] Starting makepkg…"
    notify-send -a 'N0ctOS PKGBUILD compiler' -t 5000 \
        -i system-run \
        "[$COUNT/$TOTAL] Building: $BASENAME" "Started compiling…"

    (
        cd "$DIR" || exit 1
        makepkg -sCcf --sign
    )
    BUILD_EXIT=$?

    if [ $BUILD_EXIT -eq 0 ]; then
      # delete old pkg files
        rm -rfv $SCRIPT_DIR/__deployed__/x86_64/$BASENAME-*
      # move newly built files
        mv $SCRIPT_DIR/$BASENAME/*.pkg.* "$SCRIPT_DIR/__deployed__/x86_64/" -v
      
        echo "  [OK] Build succeeded: $BASENAME"
        notify-send -a 'N0ctOS PKGBUILD compiler' -t 5000 \
            -i dialog-ok-apply \
            "[$COUNT/$TOTAL] Done: $BASENAME" "Build completed successfully."
        (( BUILT++ ))
    else
        echo "  [ERROR] Build failed for $BASENAME (exit $BUILD_EXIT)"
        notify-send -a 'N0ctOS PKGBUILD compiler' -t 10000 \
            -i dialog-error \
            "[$COUNT/$TOTAL] FAILED: $BASENAME" "makepkg exited with code $BUILD_EXIT."
        (( FAILED++ ))
    fi
done

# =========================
# Summary
# =========================
echo
echo "══════════════════════════════════════"
echo "  Total:   $TOTAL"
echo "  Built:   $BUILT"
echo "  Skipped: $SKIPPED (no PKGBUILD)"
echo "  Failed:  $FAILED"
echo "══════════════════════════════════════"
echo "Done."

if [ $FAILED -eq 0 ]; then
    notify-send -a 'N0ctOS PKGBUILD compiler' -t 8000 \
        -i system-run \
        'N0ctOS PKGBUILD compiler — Done' \
        "✔ $BUILT built  |  $SKIPPED skipped  |  $FAILED failed"
else
    notify-send -a 'N0ctOS PKGBUILD compiler' -t 10000 \
        -i system-run \
        'N0ctOS PKGBUILD compiler — Done (with errors)' \
        "✔ $BUILT built  |  $SKIPPED skipped  |  ✘ $FAILED failed"
fi

exit $BUILD_EXIT